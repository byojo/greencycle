/* pages/story/story.wxss */
.page {
  min-height: 100vh;
  background: #F7F8FA;
  padding-bottom: 200rpx;
}

/* === Nav === */
.nav {
  
  display: flex;
  align-items: center;
  justify-content: center;
  background: #FFFFFF;
  
  
  
  border-bottom: 1rpx solid #F3F4F6;
  padding-top: env(safe-area-inset-top);
}
.nav-inner {
  height: 88rpx;
  display: flex;
  align-items: center;
}
.nav-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1F2937;
}
.nav-action {
  position: absolute;
  right: 32rpx;
  font-size: 28rpx;
  color: #07C160;
  font-weight: 500;
}

/* === 横滑 Tabs === */
.tabs {
  white-space: nowrap;
  background: #FFFFFF;
  padding: 24rpx 32rpx;
  position: sticky;
  top: calc(88rpx + env(safe-area-inset-top));
  z-index: 19;
  border-bottom: 1rpx solid #F3F4F6;
}
.tab {
  font-size: 28rpx;
  color: #6B7280;
  padding: 8rpx 0;
  position: relative;
  display: inline-block;
  margin-right: 48rpx;
}
.tab.active {
  color: #1F2937;
  font-weight: 700;
  font-size: 32rpx;
}
.tab.active::after {
  content: '';
  position: absolute;
  bottom: -4rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 36rpx;
  height: 6rpx;
  background: #07C160;
  border-radius: 4rpx;
}

/* === 头条 Feature === */
.feature {
  margin: 24rpx 32rpx 0;
  background: #FFFFFF;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.05);
}
.feature-cover {
  position: relative;
  height: 360rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 128rpx;
  background: linear-gradient(135deg, #A7F3D0 0%, #6EE7B7 50%, #34D399 100%);
}
.cover-emoji {
  font-size: 128rpx;
  line-height: 1;
}
.feature-cover .play {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  background: rgba(0, 0, 0, 0.55);
  color: #FFFFFF;
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
  font-weight: 500;
}
.feature-body {
  padding: 28rpx;
}
.feature-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1F2937;
  line-height: 1.4;
}
.feature-desc {
  font-size: 24rpx;
  color: #6B7280;
  margin-top: 12rpx;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.feature-meta {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-top: 20rpx;
  font-size: 24rpx;
  color: #9CA3AF;
}
.meta-item {
  display: inline-flex;
  align-items: center;
}
.meta-author {
  margin-left: auto;
  color: #6B7280;
  font-size: 24rpx;
}

/* === 列表 === */
.story-list {
  padding: 0 32rpx;
  margin-top: 24rpx;
}
.story-item {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 24rpx;
  display: flex;
  gap: 24rpx;
  margin-bottom: 24rpx;
}
.story-cover {
  width: 220rpx;
  height: 220rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #FED7AA 0%, #FB923C 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 80rpx;
  flex-shrink: 0;
}
.story-body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}
.story-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1F2937;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.story-desc {
  font-size: 22rpx;
  color: #6B7280;
  margin-top: 8rpx;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.story-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: 22rpx;
  color: #9CA3AF;
  margin-top: 8rpx;
  flex-wrap: wrap;
}
.tag {
  font-size: 20rpx;
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
  font-weight: 500;
}
.tag-video {
  background: #FEE2E2;
  color: #DC2626;
}
.tag-image {
  background: #DBEAFE;
  color: #2563EB;
}
.meta-time {
  margin-left: auto;
}

.empty {
  padding: 60rpx 0;
  text-align: center;
}
.empty-text {
  font-size: 26rpx;
  color: #9CA3AF;
}

.footer {
  text-align: center;
  padding: 32rpx;
  font-size: 22rpx;
  color: #9CA3AF;
}
