<!--pages/profile/profile.wxml-->
<view class="page">
  <!-- 顶部用户卡 -->
  <view class="header">
    <view class="user-row">
      <view class="avatar">{{avatarText}}</view>
      <view class="user-info">
        <view class="name-row">
          <text class="nickname">{{nickname}}</text>
          <text wx:if="{{verified}}" class="verified">已认证</text>
        </view>
        <view class="level">
          <text class="vip">🌳 {{vipLevel}}</text>
          <text class="sep">·</text>
          <text>{{orderDesc}}</text>
        </view>
      </view>
    </view>
    <view class="setting" bindtap="showSetting">⚙️</view>
  </view>

  <!-- 4 个数据统计：积分 / 减碳 / 订单数 / 在用 -->
  <view class="stats">
    <view class="stat-item" bindtap="goPoints">
      <view class="stat-num">{{pointsText}}</view>
      <view class="stat-label">积分</view>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <view class="stat-num">{{carbonText}}</view>
      <view class="stat-label">减碳(kg)</view>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <view class="stat-num">{{orderCountText}}</view>
      <view class="stat-label">订单数</view>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <view class="stat-num">{{inUseText}}</view>
      <view class="stat-label">在用</view>
    </view>
  </view>

  <!-- 功能列表（我的订单已隐藏：去掉 即可恢复） -->
  <view class="menu-list">
    <view class="list-row" bindtap="goOrders">
      <view class="row-icon" style="background:#DBEAFE;color:#2563EB">📦</view>
      <view class="row-label">我的订单</view>
      <view class="row-extra">{{orderCountText}} 单</view>
      <view class="row-arrow">›</view>
    </view>
    <view class="list-row" bindtap="goAddresses">
      <view class="row-icon" style="background:#E8F8EE;color:#07C160">📍</view>
      <view class="row-label">我的地址</view>
      <view class="row-extra">{{addressCountText}} 个</view>
      <view class="row-arrow">›</view>
    </view>
    <view class="list-row" bindtap="goInvite">
      <view class="row-icon" style="background:#FCE7F3;color:#DB2777">👥</view>
      <view class="row-label">邀请好友</view>
      <view class="row-extra">得 50 积分</view>
      <view class="row-arrow">›</view>
    </view>
    <view class="list-row" bindtap="goService">
      <view class="row-icon" style="background:#E0E7FF;color:#4F46E5">💬</view>
      <view class="row-label">联系客服</view>
      <view class="row-extra">在线</view>
      <view class="row-arrow">›</view>
    </view>
    <view class="list-row" bindtap="goSettings">
      <view class="row-icon" style="background:#F3F4F6;color:#6B7280">⚙️</view>
      <view class="row-label">设置</view>
      <view class="row-arrow">›</view>
    </view>
    <view class="list-row" bindtap="goAbout">
      <view class="row-icon" style="background:#FEF3C7;color:#D97706">✈️</view>
      <view class="row-label">关于</view>
      <view class="row-extra">v{{version}}</view>
      <view class="row-arrow">›</view>
    </view>
  </view>

  <!-- 底部 logo + 版本 -->
  <view class="footer">
    <view class="footer-logo">✈️</view>
    <view class="footer-name">纸飞机</view>
    <view class="footer-version">v{{version}}</view>
    <view class="footer-slogan">让每一件旧物，都值得被温柔对待 ✈️</view>
  </view>
</view>
