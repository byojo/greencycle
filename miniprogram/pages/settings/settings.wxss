/* pages/settings/settings.wxss */
.page {
  min-height: 100vh;
  background: #F7F8FA;
  padding-bottom: 200rpx;
}

/* ============ 顶部导航 ============ */
.nav {
  height: 88rpx;
  background: #FFFFFF;
  display: flex;
  align-items: center;
  position: sticky;
  top: 0;
  z-index: 10;
  border-bottom: 1rpx solid #F3F4F6;
}
.nav-back {
  width: 80rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.back-icon {
  font-size: 56rpx;
  color: #1F2937;
  font-weight: 300;
  line-height: 1;
}
.nav-title {
  flex: 1;
  text-align: center;
  font-size: 34rpx;
  font-weight: 600;
  color: #1F2937;
}

/* ============ 分组 ============ */
.group {
  margin: 24rpx 0;
}
.group-title {
  font-size: 24rpx;
  color: #6B7280;
  padding: 8rpx 32rpx 16rpx;
}
.group-content {
  background: #FFFFFF;
  margin: 0 32rpx;
  border-radius: 24rpx;
  overflow: hidden;
}

/* ============ 单行 cell ============ */
.cell {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid #F3F4F6;
  min-height: 96rpx;
}
.cell:last-child { border-bottom: none; }
.cell:active { background: #F9FAFB; }

.cell-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.cell-icon {
  font-size: 36rpx;
  width: 48rpx;
  text-align: center;
}
.cell-label {
  font-size: 30rpx;
  color: #1F2937;
}

.cell-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.cell-value {
  font-size: 28rpx;
  color: #9CA3AF;
}
.cell-value.verified { color: #07C160; }
.cell-value.unverified { color: #F59E0B; }
.cell-value.has-update { color: #EF4444; }
.cell-arrow {
  font-size: 32rpx;
  color: #C0C4CC;
  font-weight: 300;
  line-height: 1;
}

/* ============ 退出登录 ============ */
.logout-wrap {
  margin: 48rpx 32rpx 0;
}
.logout-btn {
  background: #FFFFFF;
  color: #EF4444;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 100rpx;
  padding: 24rpx 0;
  border: 2rpx solid #FEE2E2;
  line-height: 1.4;
}
.logout-btn::after { border: none; }
