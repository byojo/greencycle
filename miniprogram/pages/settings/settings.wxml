<!--pages/settings/settings.wxml-->
<view class="page">
  <!-- 顶部导航 -->
  <view class="nav">
    <view class="nav-back" bindtap="onBack">
      <text class="back-icon">‹</text>
    </view>
    <view class="nav-title">设置</view>
  </view>

  <!-- 账户安全 -->
  <view class="group">
    <view class="group-title">账户安全</view>
    <view class="group-content">
      <view class="cell" bindtap="onPhone">
        <view class="cell-left">
          <text class="cell-icon">📱</text>
          <text class="cell-label">手机号</text>
        </view>
        <view class="cell-right">
          <text class="cell-value">{{phoneText}}</text>
          <text class="cell-arrow">›</text>
        </view>
      </view>

      <view class="cell" bindtap="onWechat">
        <view class="cell-left">
          <text class="cell-icon">💬</text>
          <text class="cell-label">微信账号</text>
        </view>
        <view class="cell-right">
          <text class="cell-value">已绑定</text>
          <text class="cell-arrow">›</text>
        </view>
      </view>

      <view class="cell" bindtap="onRealname">
        <view class="cell-left">
          <text class="cell-icon">🆔</text>
          <text class="cell-label">实名认证</text>
        </view>
        <view class="cell-right">
          <text class="cell-value {{verified ? 'verified' : 'unverified'}}">{{verifiedText}}</text>
          <text class="cell-arrow">›</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 消息通知 -->
  <view class="group">
    <view class="group-title">消息通知</view>
    <view class="group-content">
      <view class="cell">
        <view class="cell-left">
          <text class="cell-icon">🔔</text>
          <text class="cell-label">订单推送</text>
        </view>
        <view class="cell-right">
          <switch checked="{{pushOrder}}" bindchange="onTogglePush" data-key="pushOrder" color="#07C160"/>
        </view>
      </view>

      <view class="cell">
        <view class="cell-left">
          <text class="cell-icon">💚</text>
          <text class="cell-label">环保资讯</text>
        </view>
        <view class="cell-right">
          <switch checked="{{pushNews}}" bindchange="onTogglePush" data-key="pushNews" color="#07C160"/>
        </view>
      </view>

      <view class="cell">
        <view class="cell-left">
          <text class="cell-icon">🎉</text>
          <text class="cell-label">活动福利</text>
        </view>
        <view class="cell-right">
          <switch checked="{{pushActivity}}" bindchange="onTogglePush" data-key="pushActivity" color="#07C160"/>
        </view>
      </view>
    </view>
  </view>

  <!-- 通用 -->
  <view class="group">
    <view class="group-title">通用</view>
    <view class="group-content">
      <view class="cell" bindtap="onLanguage">
        <view class="cell-left">
          <text class="cell-icon">🌐</text>
          <text class="cell-label">语言</text>
        </view>
        <view class="cell-right">
          <text class="cell-value">简体中文</text>
          <text class="cell-arrow">›</text>
        </view>
      </view>

      <view class="cell" bindtap="onClearCache">
        <view class="cell-left">
          <text class="cell-icon">🧹</text>
          <text class="cell-label">清除缓存</text>
        </view>
        <view class="cell-right">
          <text class="cell-value">{{cacheText}}</text>
          <text class="cell-arrow">›</text>
        </view>
      </view>

      <view class="cell" bindtap="onAgreement">
        <view class="cell-left">
          <text class="cell-icon">📄</text>
          <text class="cell-label">用户协议</text>
        </view>
        <view class="cell-right">
          <text class="cell-arrow">›</text>
        </view>
      </view>

      <view class="cell" bindtap="onPrivacy">
        <view class="cell-left">
          <text class="cell-icon">🔒</text>
          <text class="cell-label">隐私政策</text>
        </view>
        <view class="cell-right">
          <text class="cell-arrow">›</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 关于 -->
  <view class="group">
    <view class="group-content">
      <view class="cell" bindtap="onAbout">
        <view class="cell-left">
          <text class="cell-icon">✈️</text>
          <text class="cell-label">关于纸飞机</text>
        </view>
        <view class="cell-right">
          <text class="cell-value">v{{version}}</text>
          <text class="cell-arrow">›</text>
        </view>
      </view>

      <view class="cell" bindtap="onCheckUpdate">
        <view class="cell-left">
          <text class="cell-icon">🔄</text>
          <text class="cell-label">检查更新</text>
        </view>
        <view class="cell-right">
          <text class="cell-value {{hasUpdate ? 'has-update' : ''}}">{{updateText}}</text>
          <text class="cell-arrow">›</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 退出登录 -->
  <view class="logout-wrap">
    <button class="logout-btn" bindtap="onLogout">退出登录</button>
  </view>

  <view class="safe-area-bottom" style="height: 200rpx;"></view>
</view>
