/* pages/home/home.wxss */
.page {
  min-height: 100vh;
  background: #F7F8FA;
  padding-bottom: 200rpx;
}

.banner {
  background: linear-gradient(135deg, #07C160 0%, #06AD56 50%, #059142 100%);
  padding: 30rpx 32rpx 80rpx;
  position: relative;
  overflow: hidden;
}
.banner::before {
  content: '';
  position: absolute;
  top: -100rpx;
  right: -100rpx;
  width: 400rpx;
  height: 400rpx;
  background: radial-gradient(circle, rgba(255,255,255,0.15) 0%, transparent 70%);
  border-radius: 50%;
}
.banner::after {
  content: '';
  position: absolute;
  bottom: -160rpx;
  left: -80rpx;
  width: 320rpx;
  height: 320rpx;
  background: radial-gradient(circle, rgba(255,140,66,0.25) 0%, transparent 70%);
  border-radius: 50%;
}

.location {
  display: flex;
  align-items: center;
  gap: 8rpx;
  color: rgba(255,255,255,0.95);
  font-size: 28rpx;
  font-weight: 500;
  margin-top: 16rpx;
}
.location .arrow {
  font-size: 22rpx;
  opacity: 0.8;
  margin-left: 4rpx;
}

.greeting {
  color: white;
  margin-top: 24rpx;
}
.greeting .hello {
  font-size: 26rpx;
  opacity: 0.9;
}
.greeting .name {
  font-size: 40rpx;
  font-weight: 700;
  margin-top: 4rpx;
}

.search {
  background: white;
  border-radius: 48rpx;
  padding: 22rpx 32rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 36rpx;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.08);
}
.search .search-icon {
  font-size: 32rpx;
  color: #9CA3AF;
}
.search .search-input {
  flex: 1;
  font-size: 28rpx;
  color: #1F2937;
}

/* 分类 */
.categories {
  margin-top: -60rpx;
  margin-left: 32rpx;
  margin-right: 32rpx;
  background: white;
  border-radius: 32rpx;
  padding: 36rpx 28rpx 24rpx;
  box-shadow: 0 16rpx 48rpx rgba(0,0,0,0.06);
  position: relative;
  z-index: 5;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}
.cat-card {
  padding: 12rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.categories .cat-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  margin: 0 auto 12rpx;
}
.categories .cat-label {
  font-size: 24rpx;
  color: #1F2937;
  font-weight: 500;
  text-align: center;
}

/* 碳积分卡片 */
.points-card {
  margin: 32rpx 32rpx 0;
  background: linear-gradient(135deg, #FF8C42 0%, #FF6B1A 100%);
  border-radius: 32rpx;
  padding: 32rpx;
  color: white;
  display: flex;
  align-items: center;
  gap: 24rpx;
  box-shadow: 0 12rpx 40rpx rgba(255, 140, 66, 0.25);
}
.points-icon {
  width: 96rpx;
  height: 96rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
}
.points-info { flex: 1; }
.points-num {
  font-size: 44rpx;
  font-weight: 700;
}
.points-label {
  font-size: 24rpx;
  opacity: 0.9;
  margin-top: 4rpx;
}
.points-arrow {
  font-size: 26rpx;
  opacity: 0.9;
}

/* 区块 */
.section {
  padding: 40rpx 32rpx 0;
}
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}
.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1F2937;
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.section-more {
  font-size: 26rpx;
  color: #6B7280;
}

/* 故事横滑 */
.story-scroll {
  white-space: nowrap;
}
.story-card {
  display: inline-block;
  width: 320rpx;
  margin-right: 24rpx;
  background: white;
  border-radius: 28rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.04);
  vertical-align: top;
}
.story-cover {
  height: 220rpx;
  background: linear-gradient(135deg, #87CEEB 0%, #B0E0E6 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 88rpx;
  position: relative;
}
.story-tag {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  background: rgba(0,0,0,0.5);
  color: white;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}
.story-body {
  padding: 20rpx 24rpx;
}
.story-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #1F2937;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.story-meta {
  font-size: 22rpx;
  color: #9CA3AF;
  margin-top: 12rpx;
}

/* 环保承诺 */
.commit {
  margin: 24rpx;
  padding: 28rpx 32rpx;
  background: linear-gradient(135deg, #ECFDF5 0%, #D1FAE5 100%);
  border: 2rpx solid #A7F3D0;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
}
.commit-icon {
  font-size: 56rpx;
  flex-shrink: 0;
}
.commit-text {
  flex: 1;
  min-width: 0;
}
.commit-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1F2937;
  line-height: 1.4;
}
.commit-sub {
  font-size: 22rpx;
  color: #6B7280;
  margin-top: 4rpx;
}

/* 加入我们 */
.join-us {
  margin: 0 24rpx 200rpx;
  padding: 28rpx 32rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}
.join-icon {
  font-size: 48rpx;
}
.join-text {
  flex: 1;
}
.join-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1F2937;
}
.join-sub {
  font-size: 22rpx;
  color: #6B7280;
  margin-top: 4rpx;
}
.join-arrow {
  font-size: 40rpx;
  color: #D1D5DB;
  font-weight: 300;
}
