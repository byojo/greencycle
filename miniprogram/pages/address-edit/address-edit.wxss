/* pages/address-edit/address-edit.wxss */
.page {
  min-height: 100vh;
  background: #F7F8FA;
  padding-bottom: 200rpx;
}

/* ============ 顶部导航 ============ */
.nav {
  
  background: #FFFFFF;
  display: flex;
  align-items: center;
  
  
  
  border-bottom: 1rpx solid #F3F4F6;
  padding-top: env(safe-area-inset-top);
}
.nav-inner {
  height: 88rpx;
  display: flex;
  align-items: center;
}
.nav-back {
  width: 80rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.back-icon {
  font-size: 56rpx;
  color: #1F2937;
  font-weight: 300;
  line-height: 1;
}
.nav-title {
  flex: 1;
  text-align: center;
  font-size: 34rpx;
  font-weight: 600;
  color: #1F2937;
}
.nav-action {
  width: 120rpx;
  text-align: center;
  font-size: 30rpx;
  color: #07C160;
  font-weight: 600;
  padding-right: 24rpx;
}

/* ============ 表单 ============ */
.form {
  background: #FFFFFF;
  margin: 24rpx 32rpx 0;
  border-radius: 24rpx;
  overflow: hidden;
}
.form-item {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #F3F4F6;
  gap: 24rpx;
}
.form-item:last-child {
  border-bottom: none;
}
.form-item-block {
  flex-direction: column;
  align-items: stretch;
  position: relative;
}
.form-item-between {
  justify-content: space-between;
}

.picker-item {
  position: relative;
}
.form-picker-value {
  flex: 1;
  font-size: 28rpx;
  color: #1F2937;
  line-height: 44rpx;
}
.form-picker-value.placeholder {
  color: #9CA3AF;
}
.form-arrow {
  font-size: 36rpx;
  color: #C0C4CC;
  font-weight: 300;
  line-height: 1;
  margin-left: 8rpx;
}
.form-label {
  font-size: 28rpx;
  color: #1F2937;
  font-weight: 500;
  width: 120rpx;
  flex-shrink: 0;
}
.form-item-block .form-label {
  width: auto;
  margin-bottom: 16rpx;
}
.form-input {
  flex: 1;
  font-size: 28rpx;
  color: #1F2937;
  padding: 0;
  height: 44rpx;
  line-height: 44rpx;
}
.form-textarea {
  font-size: 28rpx;
  color: #1F2937;
  min-height: 120rpx;
  width: 100%;
  padding: 0;
  line-height: 1.5;
  box-sizing: border-box;
}
.form-counter {
  position: absolute;
  right: 32rpx;
  bottom: 28rpx;
  font-size: 22rpx;
  color: #9CA3AF;
}

/* ============ 标签选择 ============ */
.tag-list {
  flex: 1;
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.tag-item {
  font-size: 24rpx;
  padding: 10rpx 24rpx;
  border-radius: 100rpx;
  background: #F3F4F6;
  color: #6B7280;
  border: 2rpx solid transparent;
  line-height: 1;
}
.tag-item.active {
  background: #E8F8EE;
  color: #06A050;
  border-color: #07C160;
  font-weight: 600;
}

/* ============ 删除按钮 ============ */
.delete-wrap {
  margin: 48rpx 32rpx 0;
}
.btn-delete {
  width: 100%;
  background: #FFFFFF;
  color: #EF4444;
  font-size: 30rpx;
  font-weight: 500;
  border-radius: 24rpx;
  padding: 28rpx 0;
  border: 2rpx solid #FECACA;
  line-height: 1;
}
.btn-delete::after {
  border: none;
}
