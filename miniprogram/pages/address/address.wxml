<!--pages/address/address.wxml-->
<view class="page">
  <view class="nav">
    <view class="nav-back" bindtap="goBack">‹</view>
    <view class="nav-title">{{selectMode ? '选择地址' : '地址管理'}}</view>
    <view wx:if="{{!selectMode}}" class="nav-manage" bindtap="onManage">{{manageText}}</view>
    <view wx:else class="nav-manage"></view>
  </view>

  <!-- 地址列表 -->
  <view wx:if="{{list && list.length > 0}}" class="addr-list">
    <view
      wx:for="{{list}}"
      wx:key="id"
      class="addr-item {{selectMode ? 'selectable' : ''}} {{item.isDefault ? 'default' : ''}}"
      data-addr="{{item}}"
      bindtap="{{selectMode ? 'onSelect' : ''}}"
    >
      <view class="addr-info">
        <view class="addr-name-row">
          <text class="addr-name">{{item.name}}</text>
          <text class="addr-phone">{{item.phone}}</text>
          <text wx:if="{{item.isDefault}}" class="default-badge">默认</text>
        </view>
        <view class="addr-detail">
          {{item.province}} {{item.city}} {{item.district}} {{item.detail}}
        </view>
        <view wx:if="{{item.tag}}" class="addr-tag">{{item.tag}}</view>
      </view>
      <view wx:if="{{!selectMode}}" class="addr-actions">
        <view class="action" catchtap="onEdit" data-id="{{item.id}}">
          <text class="action-icon edit">✎</text>
          <text>编辑</text>
        </view>
        <view wx:if="{{!item.isDefault}}" class="action" catchtap="onSetDefault" data-id="{{item.id}}">
          <text class="action-icon default-mark">✓</text>
          <text>设为默认</text>
        </view>
        <view class="action danger" catchtap="onDelete" data-id="{{item.id}}">
          <text class="action-icon delete">🗑</text>
          <text>删除</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view wx:else class="empty">
    <view class="empty-icon">🗑️</view>
    <view class="empty-text">还没有添加地址</view>
    <view class="empty-sub">添加地址后，可用于下单和回收预约</view>
    <view class="empty-btn" bindtap="onAdd">+ 新增地址</view>
  </view>

  <!-- 底部固定按钮 -->
  <view wx:if="{{list && list.length > 0}}" class="add-bar">
    <view class="add-btn" bindtap="onAdd">
      <text class="plus">+</text>
      <text>新增地址</text>
    </view>
  </view>
</view>
