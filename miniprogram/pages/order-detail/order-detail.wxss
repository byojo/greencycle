/* pages/order-detail/order-detail.wxss */
.page {
  min-height: 100vh;
  background: #F7F8FA;
  padding-bottom: 200rpx;
}

/* ============ 顶部导航 ============ */
.nav {
  
  display: flex;
  align-items: center;
  background: #FFFFFF;
  
  
  
  border-bottom: 1rpx solid #F3F4F6;
  padding-top: env(safe-area-inset-top);
}
.nav-inner {
  height: 88rpx;
  display: flex;
  align-items: center;
}
.nav-back {
  width: 80rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: #1F2937;
}
.nav-title {
  flex: 1;
  text-align: center;
  font-size: 34rpx;
  font-weight: 600;
  color: #1F2937;
}
.nav-action {
  text-align: right;
  padding-right: 32rpx;
  font-size: 28rpx;
  color: #07C160;
}

/* ============ 状态条（按 status 变色） ============ */
.status-bar {
  margin: 24rpx 32rpx 0;
  padding: 40rpx 32rpx;
  border-radius: 24rpx;
  color: #FFFFFF;
  background: linear-gradient(135deg, #07C160 0%, #06A050 100%);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
}
.status-icon-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.status-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.25);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 700;
  color: #FFFFFF;
}
.status-text {
  font-size: 30rpx;
  font-weight: 600;
}
.amount {
  font-size: 56rpx;
  font-weight: 700;
  margin-top: 16rpx;
  letter-spacing: -1rpx;
}
.amount-time {
  font-size: 24rpx;
  opacity: 0.9;
  margin-top: 8rpx;
}

/* ============ 卡片 ============ */
.card {
  background: #FFFFFF;
  margin: 24rpx 32rpx 0;
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}
.card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1F2937;
  margin-bottom: 20rpx;
}

/* 物品信息 */
.item-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}
.item-thumb {
  width: 120rpx;
  height: 120rpx;
  border-radius: 20rpx;
  overflow: hidden;
  flex-shrink: 0;
  background: #F3F4F6;
}
.thumb-img {
  width: 100%;
  height: 100%;
}
.item-icon-fallback {
  width: 112rpx;
  height: 112rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  flex-shrink: 0;
}
.item-info {
  flex: 1;
  min-width: 0;
}
.item-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1F2937;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.item-desc {
  font-size: 24rpx;
  color: #6B7280;
  margin-top: 6rpx;
  line-height: 1.5;
}
.item-attrs {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 8rpx;
}
.attr-chip {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  background: #F3F4F6;
  color: #6B7280;
}
.item-price {
  font-size: 32rpx;
  font-weight: 700;
  color: #FF8C42;
  flex-shrink: 0;
}

/* ============ 时间线 ============ */
.timeline {
  position: relative;
  padding-left: 32rpx;
}
.timeline::before {
  content: '';
  position: absolute;
  left: 12rpx;
  top: 12rpx;
  bottom: 12rpx;
  width: 2rpx;
  background: #E5E7EB;
}
.timeline-item {
  position: relative;
  padding-bottom: 28rpx;
}
.timeline-item:last-child {
  padding-bottom: 0;
}
.dot {
  position: absolute;
  left: -28rpx;
  top: 12rpx;
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: #E5E7EB;
  box-shadow: 0 0 0 4rpx #FFFFFF;
}
.dot.done {
  background: #07C160;
}
.info {
  padding-left: 8rpx;
}
.info .title {
  font-size: 28rpx;
  font-weight: 500;
  color: #1F2937;
}
.info .time {
  font-size: 22rpx;
  color: #9CA3AF;
  margin-top: 4rpx;
}

/* ============ 环保贡献 ============ */
.carbon-card {
  margin: 24rpx 32rpx 0;
  padding: 28rpx;
  background: linear-gradient(135deg, #ECFDF5 0%, #D1FAE5 100%);
  border: 2rpx solid #A7F3D0;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
}
.carbon-icon {
  font-size: 56rpx;
  flex-shrink: 0;
}
.carbon-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.carbon-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1F2937;
}
.carbon-sub {
  font-size: 22rpx;
  color: #4B5563;
}
.carbon-cert {
  font-size: 24rpx;
  font-weight: 600;
  color: #07C160;
}

/* ============ 订单信息 ============ */
.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F3F4F6;
}
.info-row:last-child {
  border-bottom: none;
}
.info-key {
  font-size: 26rpx;
  color: #6B7280;
  flex-shrink: 0;
}
.info-val {
  font-size: 26rpx;
  color: #1F2937;
  font-weight: 500;
  text-align: right;
  max-width: 60%;
}

/* ============ 操作按钮 ============ */
.actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx;
  background: #FFFFFF;
  border-top: 1rpx solid #E5E7EB;
  display: flex;
  gap: 20rpx;
  z-index: 100;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}
.btn-ghost {
  flex: 1;
  height: 88rpx;
  background: #FFFFFF;
  border: 2rpx solid #E5E7EB;
  border-radius: 44rpx;
  color: #1F2937;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 84rpx;
  text-align: center;
}
.btn-ghost::after {
  border: none;
}
.btn-primary {
  flex: 1;
  height: 88rpx;
  background: linear-gradient(135deg, #07C160 0%, #06A050 100%);
  border-radius: 44rpx;
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 88rpx;
  border: none;
  box-shadow: 0 6rpx 20rpx rgba(7, 193, 96, 0.3);
  text-align: center;
}
.btn-primary::after {
  border: none;
}
