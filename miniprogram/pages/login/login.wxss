/* pages/login/login.wxss */
.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #ECFDF5 0%, #D1FAE5 50%, #F7F8FA 100%);
  padding: 120rpx 48rpx 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* === Logo === */
.logo-area {
  text-align: center;
  margin-bottom: 80rpx;
}
.logo-circle {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #07C160 0%, #06AD56 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 32rpx;
  box-shadow: 0 16rpx 40rpx rgba(7, 193, 96, 0.35);
}
.logo-emoji {
  font-size: 80rpx;
  line-height: 1;
}
.app-name {
  font-size: 56rpx;
  font-weight: 700;
  color: #1F2937;
  line-height: 1.2;
  letter-spacing: 2rpx;
}
.slogan {
  font-size: 26rpx;
  color: #6B7280;
  margin-top: 16rpx;
  line-height: 1.5;
}

/* === Features === */
.features {
  display: flex;
  gap: 56rpx;
  margin-bottom: 80rpx;
}
.feature {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}
.feature-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}
.feature-label {
  font-size: 24rpx;
  color: #6B7280;
  font-weight: 500;
}

/* === 操作 === */
.actions {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-top: auto;
  padding-top: 60rpx;
}
.btn-login {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #07C160 0%, #06A050 100%);
  color: #FFFFFF;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  line-height: 96rpx;
  border: none;
  box-shadow: 0 12rpx 32rpx rgba(7, 193, 96, 0.35);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}
.btn-login::after { border: none; }
.btn-login .wechat-icon {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 8rpx;
}
.btn-login .wechat-text {
  color: #07C160;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1;
}
.btn-login .btn-text {
  line-height: 1;
  margin-top: 2rpx;
}

.btn-skip {
  width: 100%;
  height: 88rpx;
  background: transparent;
  color: #6B7280;
  font-size: 28rpx;
  line-height: 88rpx;
}
.btn-skip::after { border: none; }

/* === 协议 === */
.agreement {
  margin-top: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 0 16rpx;
}
.agreement-check {
  width: 32rpx;
  height: 32rpx;
  border: 2rpx solid #D1D5DB;
  border-radius: 50%;
  background: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.agreement-check.checked {
  background: #07C160;
  border-color: #07C160;
}
.check-mark {
  color: #FFFFFF;
  font-size: 22rpx;
  line-height: 1;
  font-weight: 700;
}
.agreement-text {
  font-size: 22rpx;
  color: #6B7280;
  line-height: 1.4;
}
.link {
  color: #07C160;
}
