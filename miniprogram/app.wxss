/**app.wxss**/
page {
  --primary: #07C160;
  --primary-dark: #06A050;
  --primary-light: #E8F8EE;
  --accent: #FF8C42;
  --bg: #F7F8FA;
  --card: #FFFFFF;
  --text-1: #1F2937;
  --text-2: #6B7280;
  --text-3: #9CA3AF;
  --border: #E5E7EB;

  background: #F7F8FA;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue",
               "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
  font-size: 14px;
  color: #1F2937;
}

view, text, button, input, image, scroll-view, swiper, swiper-item {
  box-sizing: border-box;
}

/* 通用类 */
.container {
  padding: 0 16px;
}

.card {
  background: #FFFFFF;
  border-radius: 16px;
  padding: 16px;
  box-shadow: 0 2px 12px rgba(0,0,0,0.04);
}

.flex { display: flex; }
.flex-1 { flex: 1; }
.flex-center { display: flex; align-items: center; justify-content: center; }
.flex-between { display: flex; align-items: center; justify-content: space-between; }
.flex-col { display: flex; flex-direction: column; }
.items-center { align-items: center; }
.justify-center { justify-content: center; }
.text-center { text-align: center; }
.text-xs { font-size: 11px; }
.text-sm { font-size: 13px; }
.text-base { font-size: 14px; }
.text-lg { font-size: 16px; }
.text-xl { font-size: 18px; }
.text-2xl { font-size: 22px; }
.text-3xl { font-size: 28px; }
.font-medium { font-weight: 500; }
.font-semibold { font-weight: 600; }
.font-bold { font-weight: 700; }

.text-primary { color: #07C160; }
.text-accent { color: #FF8C42; }
.text-gray { color: #6B7280; }
.text-light { color: #9CA3AF; }

.mt-2 { margin-top: 8px; }
.mt-3 { margin-top: 12px; }
.mt-4 { margin-top: 16px; }
.mb-2 { margin-bottom: 8px; }
.mb-3 { margin-bottom: 12px; }
.mb-4 { margin-bottom: 16px; }

/* 按钮 */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 12px 24px;
  border-radius: 24px;
  font-size: 15px;
  font-weight: 600;
  border: none;
  cursor: pointer;
  transition: opacity 0.15s;
}
.btn:active { opacity: 0.8; }

.btn-primary {
  background: linear-gradient(135deg, #07C160 0%, #06A050 100%);
  color: white;
  box-shadow: 0 4px 16px rgba(7, 193, 96, 0.25);
}
.btn-primary[disabled] {
  opacity: 0.5;
  box-shadow: none;
}

.btn-secondary {
  background: #E8F8EE;
  color: #06A050;
}

.btn-ghost {
  background: white;
  color: #1F2937;
  border: 1px solid #E5E7EB;
}

/* 进度条 */
.progress {
  display: flex;
  align-items: center;
  padding: 12px 16px;
  background: linear-gradient(90deg, #ECFDF5 0%, #F0FDF4 100%);
  border-bottom: 1px solid #D1FAE5;
  font-size: 11px;
}
.progress-step {
  display: flex;
  align-items: center;
  gap: 4px;
  color: #9CA3AF;
}
.progress-step.active { color: #06A050; font-weight: 600; }
.progress-step .num {
  width: 20px;
  height: 20px;
  border-radius: 50%;
  background: #E5E7EB;
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 10px;
}
.progress-step.active .num {
  background: #07C160;
}
.progress-line {
  flex: 1;
  height: 2px;
  background: #E5E7EB;
  margin: 0 8px;
}
.progress-line.done {
  background: #07C160;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60px 16px;
  color: #9CA3AF;
}
.empty-state .icon {
  font-size: 56px;
  margin-bottom: 12px;
  opacity: 0.6;
}
.empty-state .text {
  font-size: 13px;
}

/* loading */
.loading {
  display: inline-block;
  width: 20px;
  height: 20px;
  border: 2px solid #E5E7EB;
  border-top-color: #07C160;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
@keyframes spin {
  to { transform: rotate(360deg); }
}

/* 安全区适配 */
.safe-area-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}

/* 通用 chip */
.chip {
  display: inline-flex;
  align-items: center;
  padding: 6px 14px;
  border-radius: 100px;
  font-size: 12px;
  background: #F3F4F6;
  color: #1F2937;
  margin-right: 8px;
  margin-bottom: 8px;
}
.chip.active {
  background: #07C160;
  color: white;
  font-weight: 600;
}