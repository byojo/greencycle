/* custom-tab-bar/index.wxss */
.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 160rpx;
  background: #ffffff;
  display: flex;
  align-items: flex-end;
  border-top: 1rpx solid #F3F4F6;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 999;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100rpx;
  position: relative;
  padding-bottom: 16rpx;
  box-sizing: border-box;
}

/* 普通 tab 图标 */
.tab-icon {
  font-size: 44rpx;
  color: #9CA3AF;
  line-height: 1;
  font-weight: 400;
  margin-bottom: 6rpx;
}

.tab-label {
  font-size: 22rpx;
  color: #9CA3AF;
  line-height: 1.4;
  font-weight: 500;
}

.tab-item.active .tab-icon {
  color: #07C160;
  font-weight: 600;
}

.tab-item.active .tab-label {
  color: #07C160;
  font-weight: 600;
}

/* 中间 FAB：圆形凸出 + label 用 flex 自动放底部 */
.tab-item.fab {
  justify-content: flex-end;
}

.fab-circle {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #07C160 0%, #06AD56 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  /* 圆形向上凸出 32rpx（顶部在 tab-item 之外） */
  margin-top: -32rpx;
  margin-bottom: 4rpx;
  box-shadow: 0 4rpx 12rpx rgba(7, 193, 96, 0.25);
}

.fab-icon {
  color: #ffffff;
  font-size: 50rpx;
  font-weight: 300;
  line-height: 1;
  margin-top: -2rpx;
}

.tab-item.fab .tab-label {
  color: #6B7280;
  font-size: 22rpx;
  margin: 0;
}
